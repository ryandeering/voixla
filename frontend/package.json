        "@types/node": "^22.10.5",
        "@vitejs/plugin-vue": "^5.2.1",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-vue": "^9.32.0",
        "prettier": "^3.4.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0",
        "vite": "^6.0.7",
